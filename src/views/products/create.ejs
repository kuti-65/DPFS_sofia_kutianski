<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>
  <main class="container">
    <h1><%= title %></h1>
    <form action="/products" method="post">
      <label>Nombre: <input type="text" name="name"></label><br>
      <label>Descripción: <textarea name="description"></textarea></label><br>
      <label>Imagen: <input type="text" name="image"></label><br>
      <label>Categoría: <input type="text" name="category"></label><br>
      <label>Colores: <input type="text" name="colors"></label><br>
      <label>Precio: <input type="number" name="price"></label><br>
      <button type="submit">Crear</button>
    </form>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
